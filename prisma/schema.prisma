generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

model Event {
  id        Int      @id @default(autoincrement())
  category  String
  value     String
  moodScore Int?
  trigger   String?
  notes     String?
  createdAt DateTime @default(now())
}