generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

model Event {
  id        Int      @id @default(autoincrement())

  categoryId Int

  category  Category @relation(fields: [categoryId], references: [id])

  value     String
  moodScore Int?

  triggers  EventTrigger[]
  notes     String?

  eventDate DateTime
  createdAt DateTime @default(now())

  userId    Int
  user      User @relation(fields: [userId], references: [id])
}

model Category {
  id     Int     @id @default(autoincrement())
  name   String 

  userId Int
  user   User @relation(fields: [userId], references: [id])

  events Event[]

  @@unique([userId, name])
}

model Trigger {
  id     Int     @id @default(autoincrement())
  name   String  

  userId Int
  user   User @relation(fields: [userId], references: [id])

  events EventTrigger[]

  @@unique([userId, name])
}

model EventTrigger {
  eventId   Int
  triggerId Int

  event     Event   @relation(fields: [eventId], references: [id])
  trigger   Trigger @relation(fields: [triggerId], references: [id])

  @@id([eventId, triggerId])
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String

  createdAt    DateTime @default(now())

  events     Event[]
  categories Category[]
  triggers   Trigger[]
}