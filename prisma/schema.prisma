generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

model Event {
  id        Int      @id @default(autoincrement())

  category  String
  value     String
  moodScore Int?

  triggers  EventTrigger[]
  notes     String?

  eventDate DateTime
  createdAt DateTime @default(now())
}

model Category {
  id     Int     @id @default(autoincrement())
  name   String  @unique
}

model Trigger {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  events EventTrigger[]
}

model EventTrigger {
  eventId   Int
  triggerId Int

  event     Event   @relation(fields: [eventId], references: [id])
  trigger   Trigger @relation(fields: [triggerId], references: [id])

  @@id([eventId, triggerId])
}